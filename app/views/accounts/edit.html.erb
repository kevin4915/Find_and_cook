<h1>Modifier mon compte</h1>

<%= form_with model: @user, url: account_path, method: :patch, local: true do |f| %>

  <% if @user.errors.any? %>
    <div class="errors">
      <h2><%= pluralize(@user.errors.count, "erreur") %> :</h2>
      <ul>
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :last_name, "Nom" %>
    <%= f.text_field :last_name %>
  </div>

   <div>
    <%= f.label :first_name, "Prénom" %>
    <%= f.text_field :first_name %>
  </div>

  <div>
    <%= f.label :email, "Email" %>
    <%= f.email_field :email %>
  </div>

  <hr>

  <div>
    <%= f.label :password, "Nouveau mot de passe" %>
    <%= f.password_field :password %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirmer le mot de passe" %>
    <%= f.password_field :password_confirmation %>
  </div>

  <div>
    <%= f.submit "Mettre à jour", class: "btn btn-success" %>
  </div>

<% end %>
