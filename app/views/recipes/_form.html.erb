<%= form_with(model: @recipe, local: true) do |form| %>

  <div class="form-group mb-3">
    <%= form.label :title, "Titre" %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="form-group mb-3">
    <%= form.label :ingredient, "Ingrédients" %>
    <%= form.text_area :ingredient, class: "form-control", rows: 5 %>
  </div>

  <div class="form-group mb-3">
    <%= form.label :preparation, "Préparation" %>
    <%= form.text_area :preparation, class: "form-control", rows: 8 %>
  </div>

  <%= form.submit "Enregistrer", class: "btn btn-primary mt-3" %>

<% end %>
