<div class="swipe-container">
  <% if @recipes.empty? %>
    <div class="no-recipes">
      <h3 class="mt-5 mb-5">Aucune recette trouvée, essaye avec d'autres ingrédients ! 😋</h3>
    </div>
    <% else %>
  <div class="card-stack">
    <% @recipes.each_with_index do |recipe, index| %>
      <div class="recipe-card" style="z-index: <%= @recipes.count - index %>;">
        <div class="card border-0 shadow-sm">
          <div class="recipe-image-container">
            <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c" alt="Recette">
            <div class="recipe-title-overlay">
              <h2 class="italic-title"><%= recipe.title %></h2>
            </div>
          </div>

          <div class="card-body bg-white text-center">
            <div class="d-flex justify-content-around mb-3 text-muted small border-bottom pb-2">
              <span>⭐ 5/5</span>
              <span><i class="fa-regular fa-clock"></i> 25 min</span>
              <span><i class="fa-solid fa-user-group"></i> 2 pers.</span>
            </div>

            <div class="d-flex justify-content-center gap-4 mt-4">
              <button class="btn-round btn-dislike js-dislike"><i class="fa-solid fa-xmark"></i></button>
              <button class="btn-round btn-like js-like"><i class="fa-solid fa-heart"></i></button>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <% end %>
</div>

<script>
  document.addEventListener('turbo:load', () => {
    const cards = document.querySelectorAll('.recipe-card');
    let currentIndex = 0;

    const swipeCard = (isLike) => {
      if (currentIndex < cards.length) {
        const topCard = cards[currentIndex];
        topCard.style.transition = "transform 0.6s ease, opacity 0.6s ease";
        topCard.style.transform = isLike ? "translateX(200%) rotate(30deg)" : "translateX(-200%) rotate(-30deg)";
        topCard.style.opacity = "0";
        setTimeout(() => { topCard.style.display = "none"; }, 600);
        currentIndex++;
      }
    };

    document.querySelectorAll('.js-dislike').forEach(btn => btn.addEventListener('click', () => swipeCard(false)));
    document.querySelectorAll('.js-like').forEach(btn => btn.addEventListener('click', () => swipeCard(true)));
  });
</script>
