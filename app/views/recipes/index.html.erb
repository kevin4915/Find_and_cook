<div class="show-container">
  <div class="container mt-5">

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4 mt-3">
      <% @recipes.each do |recipe| %>
        <div class="col">
          <div class="card border-0" style="height: 420px;">

            <%= link_to recipe_path(recipe) do %>
              <%= image_tag recipe.image_URL, class: "card-img-top mt-0", alt: recipe.title, style: "height: 200px; object-fit: cover;" %>
            <% end %>

            <div class="card-badges ms-2 mt-2">
              <% if recipe.is_healthy %>
                <span class="badge rounded-pill bg-warning text-white shadow-sm px-3 py-2 ms-1">
                  <i class="fa-solid fa-leaf"></i> Healthy
                </span>
              <% end %>
              <% if recipe.is_protein %>
                <span class="badge rounded-pill bg-info text-white shadow-sm px-3 py-2 ms-1">
                  <i class="fa-solid fa-bolt"></i> Protéiné
                </span>
              <% end %>
              <% if recipe.respond_to?(:is_gourmet) && recipe.is_gourmet %>
                <span class="badge rounded-pill shadow-sm px-3 py-2 text-white ms-1" style="background-color: #e84393;">
                  <i class="fa-solid fa-cookie-bite"></i> Gourmand
                </span>
              <% end %>
            </div>

            <div class="card-body">
              <%= link_to recipe_path(recipe), class: "text-decoration-none text-dark" do %>
                <h2 class="card-title"><%= recipe.title %></h2>
              <% end %>
              <p class="card-text text-muted small">
                <%= truncate(recipe.short_description, length: 80) %>
              </p>
            </div>

            <div class="card-footer mt-auto d-flex justify-content-between align-items-center">
              <div>
                <span>⭐️ <%= recipe.rating || "—" %>/5</span>
                <span class="ms-2">⏱️ <%= recipe.preparation_time || "?" %> min</span>
              </div>
              <%= link_to recipe_path(recipe),
                    data: { turbo_method: :delete, turbo_confirm: "Supprimer cette recette ?" },
                    class: "btn btn-sm border-0" do %>
                <i class="fa-solid fa-trash" style="color: #2ECC71;"></i>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
