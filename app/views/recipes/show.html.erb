<div class="container mt-4">
  <h1><%= @recipe.title %></h1>

  <p class="mt-3"><strong>Ingrédient principal :</strong><br><%= @recipe.ingredient %></p>

  <p class="mt-3"><strong>Préparation :</strong><br><%= simple_format(@recipe.preparation) %></p>

  <p class="mt-3"><strong>Note :</strong> <%= @recipe.rating %>/5</p>

  <div class="mt-4">
    <%= link_to "Modifier", edit_recipe_path(@recipe), class: "btn btn-warning" %>
    <%= link_to "Supprimer", recipe_path(@recipe),
        data: { turbo_method: :delete, turbo_confirm: "Supprimer cette recette ?" },
        class: "btn btn-danger" %>
  </div>

  <div class="mt-4">
    <%= link_to "Retour", recipes_path, class: "btn btn-secondary" %>
  </div>
</div>
