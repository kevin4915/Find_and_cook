<div class="home-hero">
  <div class="container text-center py-5">
    <div class="my-4 content-box">
      <h1 class="display-4 fw-bold text-white mb-4">Find & Cook</h1>
      <h3 class="mt-2 mb-5 text-white shadow-text">Pour de bons repas il faut de bons ingrédients, qu'as-tu sous la main ? 😋</h3>

      <%= form_with url: recipes_path, method: :post, data: { turbo: false }, class: "form-ia d-flex justify-content-center mt-3" do |f| %>
        <div class="input-group search-bar-container" style="max-width: 550px;">
          <%= f.text_field :ingredients,
                placeholder: "ex: poulet, citron, ail...",
                class: "form-control form-control-lg search-input ps-4" %>
          <%= f.submit "Cuisiner",
                class: "btn btn-success btn-search px-5" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="container my-5">
  <div id="carouselExampleInterval" class="carousel slide small-carousel shadow rounded-4 overflow-hidden mx-auto" data-bs-ride="carousel" style="max-width: 600px;">
    <div class="carousel-inner">
      <div class="carousel-item active">
        <img src="https://images.unsplash.com/photo-1593560708920-61dd98c46a4e?q=80" class="d-block w-100" alt="Pizza">
      </div>
      <div class="carousel-item">
        <img src="https://images.unsplash.com/photo-1623428187969-5da2dcea5ebf?q=80" class="d-block w-100" alt="Salade">
      </div>
      <div class="carousel-item">
        <img src="https://images.unsplash.com/photo-1551024601-bec78aea704b?q=80" class="d-block w-100" alt="Donuts">
      </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleInterval" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleInterval" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Next</span>
    </button>
  </div>

  <div class="text-center mt-5 py-4">
    <h4 class="fw-bold mb-4">Rejoignez la communauté Find & Cook</h4>
    <div class="d-flex justify-content-center gap-4">
      <a href="#" class="text-dark"><i class="fa-brands fa-instagram fa-2x"></i></a>
      <a href="#" class="text-dark"><i class="fa-brands fa-tiktok fa-2x"></i></a>
      <a href="#" class="text-dark"><i class="fa-brands fa-facebook fa-2x"></i></a>
    </div>
  </div>
</div>
